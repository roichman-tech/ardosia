# ---------------------------------------------------------------------------
# Environment variables for Ardosia
#
# Copy to `.env` for local dev and fill in real values. The SAME keys must be
# set in Vercel for BOTH the Preview and Production environments
# (Project → Settings → Environment Variables). `NEXT_PUBLIC_*` vars are inlined
# at build time, so each Vercel environment builds with its own values.
# ---------------------------------------------------------------------------

# --- Supabase --------------------------------------------------------------
# Project URL and the RESTRICTED (publishable / anon) key. This key is bound to
# the RLS-enforced `anon` role — do NOT use the service_role / secret key here.
# Accepts a legacy anon key (eyJ...) or a new-style publishable key (sb_publishable_...).
# Found in: Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>

# --- Clerk -----------------------------------------------------------------
# Use test keys (pk_test_ / sk_test_) for local + preview, live keys for production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Upstash Redis ---------------------------------------------------------
REDIS_URL=https://<your-db>.upstash.io
REDIS_TOKEN=<upstash-rest-token>
