# ---------------------------------------------------------------------------
# Environment variables for Ardosia
#
# Copy to `.env` for local dev and fill in real values. The SAME keys must be
# set in Vercel for BOTH the Preview and Production environments
# (Project → Settings → Environment Variables). `NEXT_PUBLIC_*` vars are inlined
# at build time, so each Vercel environment builds with its own values.
# ---------------------------------------------------------------------------

# --- Clerk -----------------------------------------------------------------
# Use test keys (pk_test_ / sk_test_) for local + preview, live keys for production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Upstash Redis ---------------------------------------------------------
REDIS_URL=https://<your-db>.upstash.io
REDIS_TOKEN=<upstash-rest-token>

# --- Database (Supavisor pooler, server-only) ------------------------------
# Two restricted roles, one connection string each. Same pooler host/port; only
# the role in the username differs. NEVER prefix these NEXT_PUBLIC_ — they are
# DB-reachable credentials and must stay server-side.
#
# Use the *transaction*-mode pooler (port 6543). Passwords are set out-of-band
# (`ALTER ROLE ardosia_app PASSWORD …` / `… ardosia_catalog PASSWORD …`) per
# environment — never committed.
#
# ardosia_app    — authenticated owner dashboard (full tenant-scoped DML)
APP_DATABASE_URL=postgres://ardosia_app.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# ardosia_catalog — public catalog path (read-only + checkout_event INSERT)
CATALOG_DATABASE_URL=postgres://ardosia_catalog.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
